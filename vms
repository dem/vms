#!/bin/bash
set -euo pipefail

export LIBVIRT_DEFAULT_URI=qemu:///system

VMS_ROOT="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
source "$VMS_ROOT/lib/config.sh"
source "$VMS_ROOT/lib/common.sh"

cmd="${1:-help}"
shift || true

# Global options
args=()
for arg in "$@"; do
    case "$arg" in
        -v|--verbose) VMS_VERBOSE=1 ;;
        *) args+=("$arg") ;;
    esac
done
set -- "${args[@]+"${args[@]}"}"

case "$cmd" in
    bootstrap) source "$VMS_ROOT/commands/bootstrap.sh" "$@" ;;
    create)    source "$VMS_ROOT/commands/create.sh" "$@" ;;
    clone)     source "$VMS_ROOT/commands/clone.sh" "$@" ;;
    fork)      source "$VMS_ROOT/commands/fork.sh" "$@" ;;
    s|start)   source "$VMS_ROOT/commands/start.sh" "$@" ;;
    stop)      source "$VMS_ROOT/commands/stop.sh" "$@" ;;
    kill)      source "$VMS_ROOT/commands/kill.sh" "$@" ;;
    c|console) source "$VMS_ROOT/commands/console.sh" "$@" ;;
    v|viewer)  source "$VMS_ROOT/commands/viewer.sh" "$@" ;;
    l|list)    source "$VMS_ROOT/commands/list.sh" "$@" ;;
    destroy)   source "$VMS_ROOT/commands/destroy.sh" "$@" ;;
    help|--help|-h) usage ;;
    *) die "unknown command: $cmd" ;;
esac
